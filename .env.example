# ============================================================
# OmniWorkspace — Environment Configuration
# Copy this file to .env and fill in your API keys.
# Keys can also be set via the Settings panel in the UI.
# ============================================================

# --- LLM Provider API Keys ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Default Model Selection ---
# Format: provider/model (e.g., openai/gpt-4o, anthropic/claude-sonnet-4-20250514)
OMNI_PLANNING_MODEL=openai/gpt-4o
OMNI_EXECUTION_MODEL=openai/gpt-4o-mini
OMNI_VISION_MODEL=openai/gpt-4o

# --- Server Configuration ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Docker Sandbox ---
SANDBOX_IMAGE=omni-workspace/sandbox:latest
SANDBOX_TIMEOUT=600
SANDBOX_MAX_CONTAINERS=5
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_CPU_LIMIT=2.0

# --- Memory Engine ---
MEMORY_EMBEDDING_MODEL=all-MiniLM-L6-v2
MEMORY_DB_PATH=./data/memory
MEMORY_HNSW_M=16
MEMORY_HNSW_EF_CONSTRUCTION=200

# --- MCP Configuration ---
MCP_CONFIG_PATH=./config/mcp_servers.json

# --- Security ---
SECRET_KEY=change-me-to-a-random-string
ENCRYPTION_KEY=
