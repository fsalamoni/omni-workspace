rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Admin function: returns true if the authenticated user is the platform admin
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'fsalamoni@gmail.com';
    }

    // Isolate data by user in the SalomoneUI collection
    match /SalomoneUI/{uid}/{document=**} {
      // Allow access if the user is the owner of the data OR if they are the admin
      allow read, write: if request.auth != null && (request.auth.uid == uid || isAdmin());
    }

    // Default catch-all rule: Deny access to anything outside SalomoneUI/{uid} unless admin
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
