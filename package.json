{
  "name": "omni-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "OmniWorkspace — Open-source multi-agent orchestration platform with autonomous coding, web browsing, desktop control, and multimedia generation.",
  "author": "OmniWorkspace Contributors",
  "license": "Apache-2.0",
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev:frontend": "cd frontend && npm run dev",
    "dev:backend": "cd backend && uvicorn src.main:app --reload --host 0.0.0.0 --port 8000",
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "build": "cd frontend && npm run build",
    "docker:up": "docker compose up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "rm -rf frontend/dist frontend/node_modules"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
